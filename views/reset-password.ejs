<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Bootstrap CSS cdn -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title>Forgot Password</title>
</head>

<body class="bg-info my-5 d-flex justify-content-center align-items-center">
    <div class="w-50 bg-white rounded p-3 ">
       <h1 class="mb-3">Reset Password <%= email %></h1>
        <p class="mb-4">Enter your new password</p>
        <form action="" method="post">
            <div class="mb-3">
                <label for="newPassword" class="form-label">New Password</label>
                <input type="password" class="form-control" id="password" name="password" placeholder="Enter your password">
                <button type="submit" class="btn btn-primary w-100 mt-2">Reset Password</button>
        </form>
    </div>
</body>

</html>